server {
  listen 443 ssl http2;
  server_name dashboard.realgoodresearch.com;

  ssl_certificate /etc/letsencrypt/live/dashboard.realgoodresearch.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/dashboard.realgoodresearch.com/privkey.pem;
  ssl_session_timeout 1d;
  ssl_session_cache shared:SSL:10m;
  ssl_protocols TLSv1.2 TLSv1.3;

  location / {
    proxy_pass http://dashboard-app:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Real-IP $remote_addr;
  }
}
