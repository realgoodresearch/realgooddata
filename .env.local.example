# Local development configuration

# MinIO Configuration
MINIO_ROOT_USER=realgood_minio_admin
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password
MINIO_DATA_PATH=./data/minio
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_REGION=us-east-1

# PostgreSQL Configuration
POSTGRES_DB=data_portal
POSTGRES_USER=data_portal
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DATA_PATH=./data/postgres
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432

# Application Configuration
PRESIGNED_URL_TTL_SECONDS=300

# Let's Encrypt Configuration
LETSENCRYPT_EMAIL=ops@realgoodresearch.com

# Real Good Data Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_SESSION_SECRET=replace-with-a-separate-long-random-secret
ADMIN_SESSION_TTL_SECONDS=43200
