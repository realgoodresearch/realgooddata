{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.realgoodresearch.com/schemas/catalog-item.schema.json",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "classification",
    "listed",
    "downloadable",
    "access_reason",
    "tags"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "restricted",
        "confidential"
      ]
    },
    "listed": {
      "type": "boolean"
    },
    "downloadable": {
      "type": "boolean"
    },
    "access_reason": {
      "type": "string",
      "enum": [
        "public",
        "token_granted",
        "token_required",
        "confidential_no_download"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "file_size_bytes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "mime_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
